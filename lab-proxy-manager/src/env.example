# Daemon
DAEMON_INTERVAL_SECONDS=60
DAEMON_TIMEOUT_SECONDS=5
DAEMON_TEST_URL=http://httpbin.org/ip
DAEMON_MAX_PARALLEL=20
DAEMON_BATCH_SIZE=100
