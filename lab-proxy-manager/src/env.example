# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=proxy_db
POSTGRES_PORT=5432

# WebServer
WEBSERVER_PORT=5054
CORS_ALLOWED_ORIGIN=http://localhost:3000

# Collector
COLLECTOR_PORT=5080
